# ─────────────────────────────────────────────────────────────
#  Pratham Bank · Mitr — Voice Banking Agent — Environment
#  Copy this file to `.env` and fill in your real credentials.
#  NEVER commit the real .env file (it is gitignored).
# ─────────────────────────────────────────────────────────────

# --- Elasticsearch (data + indexing) ---
ELASTICSEARCH_URL=https://your-project.es.region.gcp.elastic.cloud:443
ELASTIC_API_KEY=your_elasticsearch_encoded_api_key_here

# --- Kibana (Agent Builder) ---
# Usually the same host as ES with ".es." -> ".kb.". The key can be the same
# as ELASTIC_API_KEY if it has Kibana privileges.
KIBANA_URL=https://your-project.kb.region.gcp.elastic.cloud
KIBANA_API_KEY=your_kibana_encoded_api_key_here
# Optional: non-default Kibana space
# KIBANA_SPACE_ID=default

# --- Sarvam AI ---
SARVAM_API_KEY=your_sarvam_api_subscription_key_here

# --- Index / agent names (sensible defaults; change only if needed) ---
ES_INDEX=bank-support-kb
TXN_INDEX=bank-transactions
CUST_INDEX=bank-customers
AGENT_ID=pratham-bank-support-agent

# Embeddings endpoint for the semantic_text KB field.
# MUST be a text_embedding inference endpoint (not a chat model).
INFERENCE_ID=.jina-embeddings-v5-text-small

# OPTIONAL chat-completion endpoint the agent reasons with (passed as
# inference_id on /converse). Leave blank to use Agent Builder's default model.
# Set to a fast endpoint (e.g. a Groq chat_completion inference endpoint) to cut latency.
AGENT_INFERENCE_ID=

# --- Sarvam model choices ---
SARVAM_STT_MODEL=saaras:v3
SARVAM_TRANSLATE_MODEL=mayura:v1

# TTS model + voice MUST match:
#   bulbul:v2 voices  -> anushka, manisha, vidya, arya (female); abhilash, karun, hitesh (male)
#   bulbul:v3 voices  -> shubh, anushka, vidya, priya, kavya ... (30+)
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_SPEAKER=anushka
# Grammatical gender of the assistant voice — drives Hindi/Marathi verb forms
# ("raha hoon" for Male, "rahi hoon" for Female). Keep aligned with the voice above.
SARVAM_SPEAKER_GENDER=Female
