# ─────────────────────────────────────────────────────────────
#  Bharat Bank Voice Agent — Environment Variables
#  Copy this file to `.env` and fill in your real credentials.
#  NEVER commit the real .env file.
# ─────────────────────────────────────────────────────────────

# --- Elasticsearch (data + indexing) ---
ELASTICSEARCH_URL=https://your-project.es.region.aws.elastic.cloud:443
ELASTIC_API_KEY=your_elasticsearch_api_key_here

# --- Kibana (Agent Builder) ---
# Can be the same key as above if it has Kibana privileges.
KIBANA_URL=https://your-project.kb.region.aws.elastic.cloud
KIBANA_API_KEY=your_kibana_api_key_here
# Optional: non-default Kibana space
# KIBANA_SPACE_ID=default

# --- Sarvam AI ---
SARVAM_API_KEY=your_sarvam_api_subscription_key_here

# --- Demo configuration (sensible defaults; change only if needed) ---
ES_INDEX=bank-support-kb
TXN_INDEX=bank-transactions
CUST_INDEX=bank-customers
INFERENCE_ID=.jina-embeddings-v5-text-small
AGENT_ID=bharat-bank-support-agent

# Sarvam model choices
SARVAM_STT_MODEL=saaras:v3
SARVAM_TRANSLATE_MODEL=mayura:v1
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_SPEAKER=anushka
